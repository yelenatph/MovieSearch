@page "/"
@rendermode RenderMode.InteractiveServer

<PageTitle>Movie Search</PageTitle>

<h2>Movie Search</h2>

<EditForm Model="@this" OnValidSubmit="HandleSearch">
    <DataAnnotationsValidator />
    <div class="input-group mb-3">
        <InputText @bind-Value="SearchQuery" class="form-control" placeholder="Enter movie title..." />
        <button class="btn btn-primary" type="submit" disabled="@IsLoading">Search</button>
    </div>
</EditForm>

@if (!string.IsNullOrEmpty(ErrorMessage))
{
    <div class="alert alert-warning">@ErrorMessage</div>
}

@if (Movies != null && Movies.Count > 0)
{
    <div class="row row-cols-1 row-cols-md-2 g-4">
        @foreach (var movie in Movies)
        {
            <div class="col">
                <div class="card h-100">
                    @if (!string.IsNullOrWhiteSpace(movie.PosterUrl))
                    {
                        <img src="@movie.PosterUrl" class="card-img-top" alt="@movie.Title poster" />
                    }
                    <div class="card-body">
                        <h5 class="card-title">@movie.Title (@movie.Year)</h5>
                        <p class="card-text text-muted">@movie.Type</p>
                        <button class="btn btn-sm btn-outline-primary"
                                @onclick="() => OpenDetails(movie.ImdbId!)">
                            Details
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
}

