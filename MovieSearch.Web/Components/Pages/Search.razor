@page "/"
@using Microsoft.AspNetCore.Components.QuickGrid

@rendermode InteractiveServer

<PageTitle>Movie Search</PageTitle>

<div class="movie-page">
    <div class="movie-container">
        <h1 class="page-title">Movie Search</h1>

        <div class="search-panel">
            <div class="search-box">
                <input class="search-input" placeholder="Enter movie title..."
                       @bind="SearchQuery" @bind:event="oninput" />
                <button class="search-btn" @onclick="HandleSearch" disabled="@IsLoading">Search</button>
            </div>

            <div class="chip-row">
                @foreach (var query in LatestSearches)
                {
                    <button class="chip-btn" @onclick="() => SearchFromHistory(query)">@query</button>
                }
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="error-alert">
                @ErrorMessage
            </div>
        }
        else
        {
            @if (HasSearched && TotalMovieCount > 0)
            {
                <div class="grid-shell">
                    <QuickGrid ItemsProvider="movieProvider" Pagination="@pagination" Class="movies-grid">
                        <PropertyColumn Property="m => m.Title" Sortable="true" />
                        <PropertyColumn Property="m => m.Year" Sortable="true" />
                        <PropertyColumn Property="m => m.Type" Sortable="true" />
                        <TemplateColumn Title="">
                            <button class="details-btn" @onclick="() => OpenDetails(context.ImdbId!)">
                                Details
                            </button>
                        </TemplateColumn>
                    </QuickGrid>
                    <div class="pager-controls">
                        <button class="pager-btn"
                                @onclick="GoToPreviousPageAsync"
                                disabled="@(!CanGoToPreviousPage)"
                                aria-label="Previous page">
                            &#8592;
                        </button>
                        <span class="pager-info">Page @(CurrentPage + 1) of @TotalPages</span>
                        <button class="pager-btn"
                                @onclick="GoToNextPageAsync"
                                disabled="@(!CanGoToNextPage)"
                                aria-label="Next page">
                            &#8594;
                        </button>
                    </div>
                </div>
            }
        }
    </div>
</div>
