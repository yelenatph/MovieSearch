@page "/movie/{ImdbId}"
@rendermode InteractiveServer

<h3>MovieDetails</h3>

@if (Movie is null)
{
    <p>Loading...</p>
}
else
{
    <div>
        <table className="table table-borderless table-sm m-3">
            <tbody className="table-style">
                <tr>
                    <td rowSpan="23">
                        <img src=@Movie.PosterUrl alt="" />
                    </td>
                </tr>
                <tr>
                    <td>Title</td>
                    <td>@Movie.Title</td>
                </tr>
                <tr>
                    <td>Year</td>
                    <td>@Movie.Year</td>
                </tr>
                <tr>
                    <td>Rated</td>
                    <td>@Movie.Rated</td>
                </tr>
                <tr>
                    <td>Released</td>
                    <td>@Movie.Released</td>
                </tr>
                <tr>
                    <td>Runtime</td>
                    <td>@Movie.Runtime</td>
                </tr>
                <tr>
                    <td>Genre</td>
                    <td>@Movie.Genre</td>
                </tr>
                <tr>
                    <td>Director</td>
                    <td>@Movie.Director</td>
                </tr>
                <tr>
                    <td>Writer</td>
                    <td>@Movie.Writer</td>
                </tr>
                <tr>
                    <td>Actors</td>
                    <td>@Movie.Actors</td>
                </tr>
                <tr>
                    <td>Plot</td>
                    <td>@Movie.Plot</td>
                </tr>
                <tr>
                    <td>Language</td>
                    <td>@Movie.Language</td>
                </tr>
                <tr>
                    <td>Country</td>
                    <td>@Movie.Country</td>
                </tr>
                <tr>
                    <td>Awards</td>
                    <td>@Movie.Awards</td>
                </tr>
                <tr>
                    <td>Metascore</td>
                    <td>@Movie.Metascore</td>
                </tr>
                <tr>
                    <td>Raiting</td>
                    <td>@Movie.ImdbRating</td>
                </tr>
                <tr>
                    <td>Votes</td>
                    <td>@Movie.ImdbVotes</td>
                </tr>
                <tr>
                    <td>Ratings</td>
                    <td>
                        <ul>
                            @foreach (var rating in Movie.Ratings)
                            {
                                <li>@rating.Source: @rating.Value</li>
                            }
                        </ul>
                    </td>
                </tr>
                <tr>
                    <td>Type</td>
                    <td>@Movie.Type</td>
                </tr>
                <tr>
                    <td>DVD</td>
                    <td>@Movie.DVD</td>
                </tr>
                <tr>
                    <td>Box Office</td>
                    <td>@Movie.BoxOffice</td>
                </tr>
                <tr>
                    <td>Production</td>
                    <td>@Movie.Production</td>
                </tr>
                <tr>
                    <td>Website</td>
                    <td>@Movie.Website</td>
                </tr>
            </tbody>
        </table>
    </div>
}

<button type="button" class="btn btn-link mt-3" @onclick="BackToSearch">Back to search</button>
