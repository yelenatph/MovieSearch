@page "/movie/{ImdbId}"
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Movie Details</PageTitle>

<div class="details-page">
    <div class="details-container">
        @if (IsLoading)
        {
            <div class="status-card">Loading movie details...</div>
        }
        else if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="status-card error-card">@ErrorMessage</div>
            <button type="button" class="back-btn mt-3" @onclick="BackToSearch">Back to search</button>
        }
        else if (Movie is not null)
        {
            <div class="details-shell">
                <aside class="poster-panel">
                    @if (HasPoster)
                    {
                        <img class="poster-image" src="@Movie.PosterUrl" alt="@Movie.Title poster" />
                    }
                    else
                    {
                        <div class="poster-fallback">No poster available</div>
                    }

                    <h1 class="movie-title">@Movie.Title</h1>
                    <p class="movie-meta">@Movie.Year | @Movie.Runtime | @Movie.Rated</p>
                </aside>

                <section class="details-panel">
                    <h2>Movie Information</h2>
                    <div class="properties-grid">
                        <div class="property"><span class="label">Type</span><span>@ValueOrDash(Movie.Type)</span></div>
                        <div class="property"><span class="label">Title</span><span>@ValueOrDash(Movie.Title)</span></div>
                        <div class="property"><span class="label">Year</span><span>@ValueOrDash(Movie.Year)</span></div>
                        <div class="property"><span class="label">Rated</span><span>@ValueOrDash(Movie.Rated)</span></div>
                        <div class="property"><span class="label">Released</span><span>@ValueOrDash(Movie.Released)</span></div>
                        <div class="property"><span class="label">Runtime</span><span>@ValueOrDash(Movie.Runtime)</span></div>
                        <div class="property"><span class="label">Genre</span><span>@ValueOrDash(Movie.Genre)</span></div>
                        <div class="property"><span class="label">Director</span><span>@ValueOrDash(Movie.Director)</span></div>
                        <div class="property"><span class="label">Writer</span><span>@ValueOrDash(Movie.Writer)</span></div>
                        <div class="property"><span class="label">Actors</span><span>@ValueOrDash(Movie.Actors)</span></div>
                        <div class="property property-full"><span class="label">Plot</span><span>@ValueOrDash(Movie.Plot)</span></div>
                        <div class="property"><span class="label">Language</span><span>@ValueOrDash(Movie.Language)</span></div>
                        <div class="property"><span class="label">Country</span><span>@ValueOrDash(Movie.Country)</span></div>
                        <div class="property"><span class="label">Awards</span><span>@ValueOrDash(Movie.Awards)</span></div>
                        <div class="property"><span class="label">Metascore</span><span>@ValueOrDash(Movie.Metascore)</span></div>
                        <div class="property"><span class="label">IMDb Rating</span><span>@ValueOrDash(Movie.ImdbRating)</span></div>
                        <div class="property"><span class="label">IMDb Votes</span><span>@ValueOrDash(Movie.ImdbVotes)</span></div>
                        <div class="property"><span class="label">DVD</span><span>@ValueOrDash(Movie.DVD)</span></div>
                        <div class="property"><span class="label">Box Office</span><span>@ValueOrDash(Movie.BoxOffice)</span></div>
                        <div class="property"><span class="label">Production</span><span>@ValueOrDash(Movie.Production)</span></div>
                        <div class="property"><span class="label">Website</span><span>@ValueOrDash(Movie.Website)</span></div>
                    </div>

                    <div class="ratings-section">
                        <h3>Ratings</h3>
                        @if (Movie.Ratings.Count > 0)
                        {
                            <ul>
                                @foreach (var rating in Movie.Ratings)
                                {
                                    <li><strong>@rating.Source:</strong> @rating.Value</li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p>-</p>
                        }
                    </div>
                </section>
            </div>

            <button type="button" class="back-btn mt-3" @onclick="BackToSearch">Back to search</button>
        }
    </div>
</div>
